flowchart TD
  start((Mulai))
  A_A["Admin: Pilih menu Laporan"]
  start --> A_A
  S_A["Sistem: Tampilkan halaman laporan"]
  A_A --> S_A
  A_B["Admin: Pilih jenis laporan (Penjualan/Stok/Terlaris)"]
  S_A --> A_B
  S_B["Sistem: Tampilkan form filter"]
  A_B --> S_B
  A_C["Admin: Set periode tanggal"]
  S_B --> A_C
  A_D["Admin: Pilih filter kategori/produk (opsional)"]
  A_C --> A_D
  A_E["Admin: Klik Generate Report"]
  A_D --> A_E
  S_C["Sistem: Validasi input"]
  A_E --> S_C
  D_A{{"Data filter valid?"}}
  S_C --> D_A
  D_A -->|Tidak| E_A["Sistem: Tampilkan error validasi"]
  E_A --> A_C
  D_A -->|Ya| S_D["Sistem: Query data dari database"]
  S_D --> D_B{{"Ada data?"}}
